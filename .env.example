# Supabase project base URL (the JS client URL, not the /rest/v1/ path)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Publishable (anon) key — non-secret, ships in the client by design.
# NEVER put the service_role key here.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# Background sync toggle: "on" (default) or "off" (local IndexedDB only).
VITE_SYNC=on
